# ============================================================
# Avila Cortinas e Persianas - .htaccess
# ============================================================

Options -Indexes

# ------------------------------------------------------------
# 1) Dominio canonico e HTTPS (301)
#    Destino oficial: https://www.cortinasavila.com.br
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} !^www\.cortinasavila\.com\.br$ [NC]
    RewriteRule ^ https://www.cortinasavila.com.br%{REQUEST_URI} [R=301,L]
</IfModule>

# ------------------------------------------------------------
# 2) Rotas limpas do catalogo
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteRule ^catalogo/([^/]+)\.html$ /catalogo/$1/ [R=301,L]
</IfModule>

# ------------------------------------------------------------
# 3) Pagina 404 personalizada
# ------------------------------------------------------------
ErrorDocument 404 /index.html

# ------------------------------------------------------------
# 4) Compressao GZIP (mod_deflate)
# ------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ------------------------------------------------------------
# 5) Cache de navegador
# ------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML - sem cache
    <FilesMatch "\.(html|htm)$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Imagens e midias - 1 mes
    <FilesMatch "\.(jpg|jpeg|png|webp|gif|ico|svg|mp4|webm)$">
        ExpiresDefault "access plus 1 month"
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>

    # CSS e JS - sem cache
    <FilesMatch "\.(css|js)$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>

    # Fontes - 1 mes
    <FilesMatch "\.(woff|woff2|ttf|otf|eot)$">
        ExpiresDefault "access plus 1 month"
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
</IfModule>

<IfModule mod_headers.c>
    Header unset ETag
    FileETag None
</IfModule>

# Bypass LiteSpeed Cache (Hostinger)
<IfModule LiteSpeed>
    CacheDisable public /
</IfModule>
<IfModule litespeed>
    CacheDisable public /
</IfModule>
